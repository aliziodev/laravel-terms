{
    "name": "aliziodev/laravel-terms",
    "description": "Lightweight Laravel package for flat terms and polymorphic term relations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "terms",
        "taxonomy",
        "tagging",
        "category"
    ],
    "authors": [
        {
            "name": "Alizio",
            "email": "aliziodev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Aliziodev\\LaravelTerms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aliziodev\\LaravelTerms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aliziodev\\LaravelTerms\\TermsServiceProvider"
            ],
            "aliases": {
                "Terms": "Aliziodev\\LaravelTerms\\Facades\\Terms"
            }
        }
    },
    "scripts": {
        "test": "php vendor/bin/pest",
        "format": "php vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
